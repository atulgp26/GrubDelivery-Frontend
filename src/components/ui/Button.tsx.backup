const SIZE_CLASSES: Record<ButtonSize, string> = {
  sm: "btn-size-sm",
  md: "btn-size-md",
  mdLg: "btn-size-md-lg",
  lg: "btn-size-lg",
  lgText: "btn-size-lg-text",
} as const;

const Button = forwardRef<HTMLButtonElement | HTMLAnchorElement, ButtonProps>(
  (props, ref) => {
    const {
      children,
      variant = "primary",
      size = "md",
      className = "",
      bgColor,
      borderColor,
      style,
      as = "button",
      ...rest
    } = props as ButtonProps & { as?: "button" | "a" };

    const buttonRest = rest as React.ButtonHTMLAttributes<HTMLButtonElement>;
    const anchorRest = rest as React.AnchorHTMLAttributes<HTMLAnchorElement>;

    const isDisabled =
      as === "button"
        ? Boolean(buttonRest.disabled)
        : Boolean(anchorRest["aria-disabled"]);

    const classes = cn(
      BASE_CLASSES,
      VARIANT_CLASSES[variant],
      SIZE_CLASSES[size],
      className,
      isDisabled && "pointer-events-none",
    );

    const mergedStyle: CSSProperties = { ...(style ?? {}) };
    if (bgColor) mergedStyle.backgroundColor = bgColor;
    if (borderColor) mergedStyle.borderColor = borderColor;

    if (as === "a") {
      const { href, rel, target, ...anchorSpecific } = anchorRest;
      return (
        <a
          ref={ref as Ref<HTMLAnchorElement>}
          className={classes}
          style={mergedStyle}
          href={href}
          rel={rel}
          target={target}
          aria-disabled={isDisabled}
          suppressHydrationWarning
          {...anchorSpecific}
        >
          {children}
        </a>
      );
    }

    return (
      <button
        ref={ref as Ref<HTMLButtonElement>}
        className={classes}
        style={mergedStyle}
        disabled={isDisabled}
        suppressHydrationWarning
        {...buttonRest}
      >
        {children}
      </button>
    );
  },
);

Button.displayName = "Button";

export default Button;
